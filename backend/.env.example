# Copy to .env — never commit .env to source control.

# ── Ollama (LLM — free, 100% local) ─────────────────────────────────────────
# Install : https://ollama.com/download
# Start   : ollama serve
# Models  : ollama pull llama3.2   (default, good accuracy)
#           ollama pull mistral    (lighter, faster on CPU)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── Tesseract (OCR — free, local) ────────────────────────────────────────────
# macOS  : brew install tesseract poppler
# Ubuntu : sudo apt install tesseract-ocr poppler-utils
# No env vars needed — pytesseract auto-detects the system binary.
