# Copy to .env — never commit .env to source control.

# ── PostgreSQL / DBeaver ────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eco_db

# ── Ollama (LLM) ─────────────────────────────────────────────────
# Full URL of the Ollama server (local or remote application URL).
# Used by POST {OLLAMA_URL}/api/generate in routes/extract.py
#
# Local dev  : OLLAMA_URL=http://localhost:11434
# Remote app : OLLAMA_URL=https://your-ollama-server.example.com
#
# To start locally: ollama serve
# To pull a model : ollama pull gpt-oss:20b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# ── Tesseract (OCR — free, local) ────────────────────────────────────
# macOS  : brew install tesseract poppler
# Ubuntu : sudo apt install tesseract-ocr poppler-utils
# No env vars needed — pytesseract auto-detects the system binary.

# ── ABR (Australian Business Register) ──────────────────────────────
# Required for /api/enrich — validates ABNs and enriches supplier name/address.
# Register for a FREE GUID at: https://www.abr.business.gov.au/Tools/WebServices
ABR_GUID=your-guid-here

# ── Geoscape (optional, improves address geocoding) ─────────────────────
# Register free at https://geoscape.com.au/geoscape-developer-centre/
# If not set, /api/geocode falls back to Nominatim (OpenStreetMap).
GEOSCAPE_API_KEY=your-key-here
