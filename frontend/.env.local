# Backend API URL
# Leave VITE_API_URL empty in development — the Vite dev proxy (vite.config.ts)
# forwards all /api/* requests to http://localhost:8000 transparently.
# Setting this to http://localhost:8000 bypasses the proxy and causes CORS errors.
#
# Only set this in production/staging where the API lives on a different origin:
#   VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=
